{{ $project := .name }}
{{ if .models }}
---
#! model-runner-service.yaml
apiVersion: v1
kind: Service
metadata:
  name: docker-model-runner
  namespace: {{ helmValue ".Values.namespace" }}
  labels:
    app: docker-model-runner
    com.docker.compose.project: {{ $project }}
    app.kubernetes.io/managed-by: Helm
spec:
  type: ClusterIP
  ports:
  - port: 80
    targetPort: 12434
    protocol: TCP
    name: http
  selector:
    app: docker-model-runner
{{ end }}
